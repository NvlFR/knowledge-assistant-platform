# Production env for VPS deployment.
#   cp .env.prod.example .env   (on the VPS) and fill in real values.
# Used with: docker compose -f docker-compose.yaml -f docker-compose.prod.yml up -d --build

# --- Domain / TLS ---
DOMAIN=ask.ftrhq.my.id
ACME_EMAIL=you@example.com        # for Let's Encrypt expiry notices

# --- Postgres (use STRONG values, DB is not exposed publicly) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-long-random-string
POSTGRES_DB=knowledge_assistant

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Tavily (web search) ---
TAVILY_API_KEY=tvly-your-tavily-key

# --- Auth (MUST be set in production) ---
APP_PASSWORD=pick-a-strong-shared-password
AUTH_SECRET=generate-with-openssl-rand-hex-32

# NOTE: NEXT_PUBLIC_BACKEND_URL and CORS_ORIGINS are handled automatically by
# docker-compose.prod.yml (frontend built with /api, backend CORS = https://DOMAIN).
