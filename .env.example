# Copy this file to .env and fill in real values before running docker-compose.

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=knowledge_assistant

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Tavily (web search) ---
TAVILY_API_KEY=tvly-your-tavily-key

# --- Auth ---
# Shared password that gates the whole app. Leave blank to disable auth
# (local dev). Set a strong value before deploying to a public VPS.
APP_PASSWORD=change-me
# Optional: independent HMAC signing key for session tokens. If blank it is
# derived from APP_PASSWORD; setting it lets you rotate/invalidate sessions.
AUTH_SECRET=

# --- Frontend ---
NEXT_PUBLIC_BACKEND_URL=http://localhost:4447
# Comma-separated origins allowed to call the backend (set to your domain on VPS).
CORS_ORIGINS=http://localhost:4448
